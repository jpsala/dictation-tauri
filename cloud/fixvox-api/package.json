{
  "name": "fixvox-api",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun run test:unit",
    "test:unit": "bun test tests/app.test.ts tests/config.test.ts tests/jobs.test.ts tests/migrations.test.ts tests/preflight.test.ts tests/providers.test.ts",
    "migrations:verify": "bun run src/postgres/verify-migrations.ts",
    "migrate:local": "bun --env-file=../../.env.postgres.local run src/postgres/migrate.ts",
    "test:postgres": "bun --env-file=../../.env.postgres.local test tests/postgres.integration.test.ts tests/repositories.integration.test.ts",
    "test:contract": "bun --env-file=../../.env.postgres.local test --timeout=30000 ../../tests/cloud-contract/bun-contract-runner.contract.ts",
    "test:contract:compare": "bun ../../tests/cloud-contract/compare-adapter-reports.contract.ts",
    "backup-manifest:local": "bun --env-file=../../.env.postgres.local run src/postgres/generate-backup-manifest.ts"
  }
}
