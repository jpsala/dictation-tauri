{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dictation Tauri",
  "version": "0.1.0",
  "identifier": "dev.jpsala.dictation-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dictation Tauri",
        "url": "index.html",
        "width": 900,
        "height": 620,
        "minWidth": 360,
        "minHeight": 320,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
