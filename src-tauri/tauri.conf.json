{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dictation Tauri",
  "version": "0.1.0",
  "identifier": "dev.jpsala.dictation-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dictation Dock",
        "url": "index.html",
        "width": 164,
        "height": 64,
        "minWidth": 164,
        "minHeight": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "focus": false,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "dock-companion",
        "title": "Dictation Companion",
        "url": "index.html?surface=companion",
        "width": 320,
        "height": 158,
        "minWidth": 320,
        "minHeight": 158,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "focus": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
