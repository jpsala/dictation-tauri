{
  "name": "dictation-tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "test:pipeline": "vitest run --config vitest.config.ts",
    "synthetic-audio:fixtures": "bun scripts/synthetic-audio-stt.ts --mode fixture-check --dry-run",
    "synthetic-audio:stt:dry-run": "bun scripts/synthetic-audio-stt.ts --mode stt-dry-run --dry-run",
    "microphone-capture:check": "bun scripts/microphone-capture.ts --mode artifact-check --dry-run",
    "microphone-capture:dry-run": "bun scripts/microphone-capture.ts --mode capture-dry-run --dry-run",
    "runtime-transcription:check": "bun scripts/runtime-transcription.ts --mode artifact-check --dry-run",
    "runtime-transcription:groq:dry-run": "bun scripts/runtime-transcription.ts --mode groq-dry-run --dry-run",
    "desktop-control:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dictation-e2e.ps1",
    "dock-companion:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dock-companion-smoke.ps1",
    "hotkey-reregistration:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/hotkey-reregistration-smoke.ps1",
    "selection-capture:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/selection-capture-smoke.ps1",
    "context:index": "bun scripts/context-index.ts",
    "context:audit": "bun scripts/agent-context-audit.ts",
    "context:refresh": "bun scripts/context-refresh.ts",
    "skills:status": "powershell -ExecutionPolicy Bypass -File scripts/toggle-skills-link.ps1 status",
    "skills:on": "powershell -ExecutionPolicy Bypass -File scripts/toggle-skills-link.ps1 on",
    "skills:off": "powershell -ExecutionPolicy Bypass -File scripts/toggle-skills-link.ps1 off",
    "skills:toggle": "powershell -ExecutionPolicy Bypass -File scripts/toggle-skills-link.ps1 toggle",
    "skills:check": "bun scripts/check-skills-junction.ts",
    "visual:check": "playwright test --workers=1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:hidden": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-tauri-dev-hidden.ps1",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@tauri-apps/api": "^2.11.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
