{
  "repositories": {
    "dictation-tauri": {
      "id": "dictation-tauri",
      "path": "/var/lib/fixvox-workspace/repos/dictation-tauri",
      "home": "/var/lib/fixvox-release",
      "branch": "main",
      "remoteName": "origin",
      "remoteUrl": "https://github.com/jpsala/dictation-tauri.git",
      "pushUrl": "git@github.com:jpsala/dictation-tauri.git",
      "gitSshCommand": "/usr/bin/ssh -F /etc/fixvox-release/ssh_config -o BatchMode=yes",
      "allowedPaths": ["admin/fixvox-web", "scripts", "docs"]
    }
  },
  "recipes": {
    "fixvox-admin-vps": {
      "id": "fixvox-admin-vps",
      "enabled": false,
      "repoId": "dictation-tauri",
      "target": "fixvox-admin-vps",
      "cwd": "/var/lib/fixvox-workspace/repos/dictation-tauri",
      "home": "/var/lib/fixvox-release",
      "rollbackId": "admin-backup",
      "env": { "PI_ADMIN_DEPLOY_SOCKET": "/run/fixvox-release/admin-deploy.sock" },
      "deploy": { "file": "/usr/bin/node", "args": ["/opt/fixvox-agent/runtime/pi-admin-deploy-client.mjs"], "timeoutMs": 300000 },
      "health": { "file": "/usr/bin/curl", "args": ["-fsS", "http://127.0.0.1:8787/healthz"], "timeoutMs": 30000 },
      "rollback": { "file": "/usr/bin/true", "args": [], "timeoutMs": 30000 }
    }
  }
}
